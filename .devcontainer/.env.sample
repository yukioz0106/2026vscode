
# ビルド前にAWS認証情報を設定
# 企画基盤Tから配布される認証情報
AWS_ACCESS_KEY_ID=<your-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-secret-access-key>
AWS_REGION=ap-northeast-1
CLAUDE_CODE_USE_BEDROCK=1

# 企画基盤Tから配布されるアカウントIDを<aws-account-id>に記載
ANTHROPIC_MODEL=arn:aws:bedrock:ap-northeast-1:<aws-account-id>:inference-profile/jp.anthropic.claude-sonnet-4-5-20250929-v1:0
ANTHROPIC_SMALL_FAST_MODEL=arn:aws:bedrock:ap-northeast-1:<aws-account-id>:inference-profile/apac.anthropic.claude-3-5-sonnet-20241022-v2:0
