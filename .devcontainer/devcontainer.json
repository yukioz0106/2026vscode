{
  "name": "claude-code-devcontainer-koizumi",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "runArgs": [
        "--env-file",
        ".devcontainer/.env"
    ],
  "mounts": [
    "source=/cafe05/koizumi/works,target=/workspaces/claude-code-sample/works,type=bind"
  ],
  "workspaceFolder": "/workspaces/claude-code-sample", 
  "privileged": true,
  "remoteUser": "root",
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code"
      ]
    }
  }
}
